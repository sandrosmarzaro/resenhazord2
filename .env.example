COMPOSE_BAKE=true
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=console

RESENHA_JID=0000000000000-0000000000@g.us
RESENHA_TEST_LID=0000000000000@g.us
RESENHAZORD2_JID=0000000000000@s.whatsapp.net
RESENHAZORD2_LID=1234567890
DEV_JID=0000000000000@s.whatsapp.net
DEV_LID=1234567890

MONGODB_URI='mongodb+srv://<username>:<password>@<clustername>.mongodb.net/<dbname>?retryWrites=true&w=majority'
MONGODB_DB_NAME=resenhazord2
DATABASE_URL='postgresql+asyncpg://user:password@host/dbname'
# docker compose interpolates these into the postgres service and the in-network DATABASE_URL
POSTGRES_USER=resenha
POSTGRES_PASSWORD=
POSTGRES_DB=resenhazord2
UPSTASH_REDIS_REST_URL=https:// <your-upstash-redis-endpoint >.upstash.io
UPSTASH_REDIS_REST_TOKEN=abcdefghijklmnopqrstuvwxyz1234567890
# LangGraph checkpointer — needs Redis Stack modules (RediSearch + RedisJSON),
# e.g. Redis Cloud free tier. Absent -> in-memory MemorySaver (no durability).
REDIS_URL=redis://default:password@your-endpoint.redislabs.com:12837

RABBITMQ_URL='amqp://guest:guest@localhost:5672/'

BNET_ID=abcdefghijklmnopqrstuvwxyz1234567890
BNET_SECRET=abcdefghijklmnopqrstuvwxyz1234567890
TMDB_API_KEY=abcdefghijklmnopqrstuvwxyz1234567890
OMDB_API_KEY=
BIBLIA_TOKEN=abcdefghijklmnopqrstuvwxyz1234567890
JAMENDO_CLIENT_ID=abcdefghijklmnopqrstuvwxyz1234567890
RAWG_API_KEY=abcdefghijklmnopqrstuvwxyz1234567890
RESTCOUNTRIES_API_KEY=rc_live_abcdefghijklmnopqrstuvwxyz1234567890
TWITCH_CLIENT_ID=abcdefghijklmnopqrstuvwxyz1234567890
TWITCH_CLIENT_SECRET=abcdefghijklmnopqrstuvwxyz1234567890
NHENTAI_MIRROR_URL=
# yt-dlp cookies for login-gated sources (Instagram). In-container path; mount the
# Netscape-format file as a secret on the core node. Empty disables auth.
YTDLP_COOKIES=
DISCORD_TOKEN=
DISCORD_SERVER_GUILD_ID=
DISCORD_DRIVE_GUILD_ID=
DISCORD_APP_ID=
TELEGRAM_TOKEN=
TELEGRAM_BOT_USERNAME=resenhazord_bot
TELEGRAM_NSFW_CHAT_IDS=
SENTRY_DSN=
SENTRY_TOKEN=

# LLM Providers (fallback order: github, mistral, groq, google)
GITHUB_TOKEN=
MISTRAL_API_KEY=
GROQ_API_KEY=
# Route agent LLM calls through LangChain instead of the httpx ProviderChain
LLM_USE_LANGCHAIN=false
# Wrap the agent in the LangGraph stateful orchestrator (multi-turn conversation)
AGENT_USE_GRAPH=false

# Upstash Vector (RAG few-shot retrieval; absent = static example slice)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# SonarQube Cloud (CI-based analysis; also a GitHub Actions secret)
SONAR_TOKEN=
