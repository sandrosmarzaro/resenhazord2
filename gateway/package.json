    "dotenv": "^16.6.1",
    "mongodb": "^6.21.0",
    "node-webpmux": "^3.2.1",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
