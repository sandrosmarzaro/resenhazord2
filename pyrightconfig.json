{
  "include": ["bot", "tests"],
  "exclude": ["**/__pycache__", "tests/factories"],
  "pythonVersion": "3.13",
  "typeCheckingMode": "standard",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "reportUnusedImport": true,
  "reportUnusedVariable": true,
  "venvPath": ".",
  "venv": ".venv"
}
